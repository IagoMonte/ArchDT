    "script": null,
    "services": [
        "NetworkManager.service"
    ],
    "custom_commands": [
        "mkdir -p /etc/sudoers.d && echo '%wheel ALL=(ALL:ALL) NOPASSWD: ALL' > /etc/sudoers.d/wheel-nopasswd && chmod 440 /etc/sudoers.d/wheel-nopasswd",
        
        
        "su - iagodt -c 'git clone https://aur.archlinux.org/yay.git && cd ./yay && makepkg -si --noconfirm && cd .. && rm -rf yay/'",
        
        "su - iagodt -c 'yay -S --noconfirm ds4drv jstest-gtk-git sc-controller-git xboxdrv game-devices-udev hid-sony-panic-fix-dkms hidapitester-git'",
        "su - iagodt -c 'yay -S --noconfirm github-desktop-bin visual-studio-code-bin simplenote-electron-bin qview'",
        "su - iagodt -c 'yay -S --noconfirm logmein-hamachi haguichi'",
        "su - iagodt -c 'yay -S --noconfirm heroic-games-launcher-bin spotify open-tv-bin'",
        "su - iagodt -c 'yay -S --noconfirm opentabletdriver'",
        "su - iagodt -c 'yay -S --noconfirm wlogout waypaper'",
        
        "su - iagodt -c 'git clone https://github.com/IagoMonte/ArchDT-dots.git &&  cd ./ArchDT-dots && git checkout -- . && cp .bashrc ~ && cp -r Wallpaper ~ && cd DOTS && mkdir -p ~/.config && cp -rn ./* ~/.config/ && cd ../.. && rm -rf ArchDT-dots/'",
       
        "su - iagodt -c 'git clone https://github.com/IagoMonte/ProfileSwitcherK500.git && cd ProfileSwitcherK500 && gcc packageTransfer.c -o lib_usb_fileSend -lusb-1.0'",
        "cp /home/iagodt/ProfileSwitcherK500/lib_usb_fileSend /usr/local/bin/ && chmod +x /usr/local/bin/lib_usb_fileSend && cp /home/iagodt/ProfileSwitcherK500/ProfileSwitcher.sh /usr/local/bin/k500ProfileSwitcher && chmod +x /usr/local/bin/k500ProfileSwitcher",
        
        "mkdir -p /home/iagodt/.config/systemd/user/default.target.wants",
        "ln -sf /home/iagodt/.config/systemd/user/swww.service /home/iagodt/.config/systemd/user/default.target.wants/swww.service",
        "ln -sf /home/iagodt/.config/systemd/user/change_wallpaper.service /home/iagodt/.config/systemd/user/default.target.wants/change_wallpaper.service",
        "ln -sf /home/iagodt/.config/systemd/user/change_wallpaper.timer /home/iagodt/.config/systemd/user/default.target.wants/change_wallpaper.timer",
        
        "wal -i /home/iagodt/Wallpaper/current/dune.png",
        "ln -sf /home/iagodt/.cache/wal/starship.toml /home/iagodt/.config/starship.toml"
    ],
    "swap": true,
    "timezone": "America/Sao_Paulo",
    "version": "3.0.11"
}
